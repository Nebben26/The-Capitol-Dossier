# Supabase (get from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Stripe Price IDs (create in Stripe dashboard → Products)
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_ANNUAL=price_xxx
STRIPE_PRICE_TRADER_MONTHLY=price_xxx
STRIPE_PRICE_TRADER_ANNUAL=price_xxx

# Alert evaluator — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the value set in Netlify environment variables
ALERT_EVALUATOR_SECRET=generate_with_node_-e_crypto_randomBytes_32_toString_hex

# Morning Brief email (Resend — sign up at https://resend.com, free tier)
RESEND_API_KEY=re_your-api-key
MORNING_BRIEF_FROM_EMAIL=brief@quivermarkets.com
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must match the value set in Netlify environment variables
MORNING_BRIEF_CRON_SECRET=generate_with_node_-e_crypto_randomBytes_32_toString_hex

# Telegram Bot — real-time push alerts (see docs/telegram-bot-setup.md for full setup)
# 1. Create bot via @BotFather in Telegram, get the token
# 2. Generate webhook secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. After deploy, register webhook: curl -X POST "https://api.telegram.org/bot<TOKEN>/setWebhook" -d "url=https://yoursite.com/api/telegram/webhook" -d "secret_token=<WEBHOOK_SECRET>"
TELEGRAM_BOT_TOKEN=bot_token_from_BotFather
TELEGRAM_WEBHOOK_SECRET=generate_with_node_-e_crypto_randomBytes_32_toString_hex
TELEGRAM_BOT_USERNAME=quivermarkets_bot

# PostHog — product analytics (https://posthog.com, free tier 1M events/month)
NEXT_PUBLIC_POSTHOG_KEY=phc_PLACEHOLDER
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — error tracking (https://sentry.io, free tier 5K errors/month)
NEXT_PUBLIC_SENTRY_DSN=https://PLACEHOLDER@sentry.io/PLACEHOLDER
SENTRY_AUTH_TOKEN=PLACEHOLDER_sntrys
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
